{
  "name": "praxis-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "typecheck": "tsc --noEmit",
    "build:rust": "bash scripts/build-rust-android.sh",
    "build:android": "pnpm dlx eas-cli@latest build --platform android --profile preview",

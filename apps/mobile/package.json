    "eas:build:dev": "pnpm dlx eas-cli@latest build --platform android --profile development",
    "eas-build-pre-install": "bash scripts/eas-build-rust.sh",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
